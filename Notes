Update env
Get-Content .env | ForEach-Object { if ($_ -match "([^=]+)=(.*)") { [System.Environment]::SetEnvironmentVariable($Matches[1], $Matches[2], "Process") } }

Check url
python -c "from dotenv import load_dotenv; import os; load_dotenv(); print(repr(os.getenv('PUBLIC_BASE_URL')))"


